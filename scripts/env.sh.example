# Local development overrides for PicoBox.
# Copy to scripts/env.sh (gitignored) and customize.
# Any var set here is picked up by task.sh when sourced manually or by tests.

# Master API token used by curl-based E2E / local dev runs.
export PICOBOX_API_TOKEN="change-me-locally"

# Override storage directory if you don't want the default .storage/.
# export PICOBOX_STORAGE_DIR="/var/lib/picobox"

# Override log directory.
# export LOG_DIR="/var/log/picobox"
